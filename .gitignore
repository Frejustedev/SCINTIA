# ─────────────────────────────────────────────────────────────────────────────
# Scintia / cintiAI — .gitignore
# RED LINES (05_CONTRAINTES_SECURITE.md): never commit patient data (DICOM),
# secrets/keys, model weights, or processing outputs. This file enforces that.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & environment ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
.secrets/

# ── Patient data — DICOM & derived medical files (NEVER commit) ──
*.dcm
*.DCM
*.dicom
*.ima
*.IMA
*.dcm30
DICOMDIR
dicomdir
**/dicom/
**/DICOM/
data/
data_raw/
raw/
# Converted medical volumes
*.nii
*.nii.gz
*.nrrd
*.mha
*.mhd

# ── Processing outputs (masks, reports, exports) ──
outputs/
output/
exports/
export/
masks/
*.pdf
# (PDFs are generated reports / re-identified material — keep out of git.
#  Add an explicit allow-list rule here later if a fixed doc PDF is ever needed.)

# ── Patient identities (re-identification material) ──
identities/
patient_identities*
*.identity

# ── AI model weights ──
*.pth
*.pt
*.onnx
*.ckpt
*.safetensors
*.h5
weights/
models_weights/
checkpoints/
.totalsegmentator/

# ── Python (backend) ──
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.Python
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# ── Node / Next.js (frontend) ──
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker / local volumes ──
.pgdata/
pgdata/

# ── Editor / OS ──
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~
