# ─────────────────────────────────────────────────────────────────────────────
# Scintia / cintiAI — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.
# No real secret must ever appear in THIS file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──
APP_NAME=Scintia
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
API_V1_PREFIX=/api/v1

# ── Backend (FastAPI) ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins (the frontend).
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ──
POSTGRES_USER=scintia
# Left empty on purpose — run scripts/init-env.sh to generate a strong local value.
POSTGRES_PASSWORD=
POSTGRES_DB=scintia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# SQLAlchemy URL used by the backend. init-env.sh fills the password to match.
DATABASE_URL=postgresql+psycopg://scintia:@postgres:5432/scintia

# ── Redis (Celery broker + result backend, cache) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth (JWT) ──
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720   # 12 h

# ── Object storage (local volume in Phase 1; gitignored) ──
STORAGE_DIR=data/objects

# ── Frontend (Next.js) ──
# Public base URL of the backend API, as seen from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Secrets — leave EMPTY here; set real values only in your local .env ──
# Application secret key (session/signing). Generate a strong random value.
SECRET_KEY=
# Key used to encrypt the patient re-identification table (`patient_identities`).
# Must be managed OUTSIDE the database. Generate a strong random value.
IDENTITY_ENCRYPTION_KEY=
# Anthropic API key — used ONLY for report drafting, with zero-retention enabled.
# Not wired in Phase 0; leave empty.
ANTHROPIC_API_KEY=
